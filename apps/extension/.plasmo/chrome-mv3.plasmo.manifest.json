{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    },
    "default_popup": "./popup.html"
  },
  "version": "0.0.1",
  "author": "Doug Silkstone <doug@withseismic.com>",
  "name": "DEV | Extension",
  "description": "Sniffle",
  "background": {
    "service_worker": "./static/background/index.ts"
  },
  "options_ui": {
    "page": "./options.html",
    "open_in_tab": true
  },
  "chrome_url_overrides": {
    "newtab": "./newtab.html"
  },
  "permissions": [
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.plasmo.com/*"
      ],
      "js": [
        "..\\src\\contents\\plasmo.ts"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*"
  ]
}
